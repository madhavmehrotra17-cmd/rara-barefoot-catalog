{
  "cleanUrls": true,
  "rewrites": [
    {
      "source": "/",
      "destination": "/catalog.html"
    },
    {
      "source": "/collections/:path*",
      "has": [
        {
          "type": "query",
          "key": "gender",
          "value": "women"
        }
      ],
      "destination": "/womens.html"
    },
    {
      "source": "/collections/:path*",
      "destination": "/mens.html"
    },
    {
      "source": "/pages/about-us",
      "destination": "/about.html"
    },
    {
      "source": "/pages/:page",
      "destination": "/:page.html"
    },
    {
      "source": "/cart",
      "destination": "/cart.html"
    }
  ]
}
