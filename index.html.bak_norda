    <script>
      document.addEventListener('DOMContentLoaded', function() {
        document.addEventListener('click', function(e) {
          const quickAddBtn = e.target.closest('.product-card__quick-add-button');
          if (quickAddBtn) {
            setTimeout(function() {
              const modals = document.querySelectorAll('.quick-buy-modal');
              modals.forEach(function(modal) {
                modal.querySelectorAll('.variant-picker__option input:checked').forEach(function(item) {
                  item.checked = false;
                });
                modal.querySelectorAll('.buy-buttons button').forEach(function(btn) {
                  btn.disabled = true;
                });
                modal.querySelectorAll('.buy-buttons button[type=submit]').forEach(function(btn) {
                  btn.textContent = 'Select Size';
                });
                modal.querySelectorAll('.buy-buttons button.shopify-payment-button__button').forEach(function(btn) {
                  btn.style.display = 'none';
                });
              });
            }, 1000);
          }

          const variantInput = e.target.closest('.quick-buy-modal input[name^="product-form-"]');
          if (variantInput) {
            const blockItem = variantInput.closest('.product-info__block-item');
            if (blockItem) {
              const checkedCount = blockItem.querySelectorAll('input[name^="product-form-"]:checked').length;
              const totalOptions = blockItem.querySelectorAll('fieldset.variant-picker__option').length;
              const productInfo = variantInput.closest('.product-info');
              
              if (productInfo) {
                const buyButtons = productInfo.querySelectorAll('.buy-buttons button');
                const submitBtn = productInfo.querySelector('.buy-buttons button[type=submit]');
                const paymentBtn = productInfo.querySelector('.buy-buttons button.shopify-payment-button__button');
                
                if (checkedCount !== totalOptions) {
                  buyButtons.forEach(btn => btn.disabled = true);
                  if (paymentBtn) paymentBtn.style.display = 'none';
                  if (submitBtn) submitBtn.textContent = 'Select Size';
                } else {
                  buyButtons.forEach(btn => btn.disabled = false);
                  if (submitBtn) submitBtn.textContent = 'Add To Cart';
                  if (paymentBtn) paymentBtn.style.display = '';
                }
              }
            }
          }
        });
      });
    </script>

