<script type="text/javascript">
        function loadClarity() {
          (function(c,l,a,r,i,t,y){
              c[a]=c[a]||function(){(c[a].q=c[a].q||[]).push(arguments)};
              t=l.createElement(r);t.async=1;t.src="https://www.clarity.ms/tag/"+i;
              y=l.getElementsByTagName(r)[0];y.parentNode.insertBefore(t,y);
          })(window, document, "clarity", "script", "tnkmyc2e1r");
        }
        let clarityLoaded = false;
        const startClarity = () => {
          if(!clarityLoaded) {
            clarityLoaded = true;
            loadClarity();
            ['scroll', 'mousemove', 'touchstart', 'click'].forEach(evt => 
              window.removeEventListener(evt, startClarity)
            );
          }
        };
        ['scroll', 'mousemove', 'touchstart', 'click'].forEach(evt => 
          window.addEventListener(evt, startClarity, {once: true, passive: true})
        );
        setTimeout(startClarity, 5000);
      </script>

<script>
document.addEventListener('DOMContentLoaded', function() {
  // Detect visitor country
  fetch('https://ipapi.co/json/')
    .then(response => response.json())
    .then(data => {
      const country = data.country_code;
      const currentHost = window.location.hostname;

      // Skip popup if user already made a choice
      const geoChoice = localStorage.getItem('geo_choice');
      if (geoChoice === 'stay' || geoChoice === 'redirected') return;

      // India store (www.rarabarefoot.in)
      if (currentHost.includes('www.rarabarefoot.in')) {
        if (country !== 'IN') {
          showGeoPopup(
            'You’re visiting from outside India. Would you like to visit our Global store instead?',
            'Continue',
            'Global Store',
            'https://www.rarabarefoot.com'
          );
        }
      }

      // Global / UAE store (www.rarabarefoot.com)
      else if (currentHost.includes('www.rarabarefoot.com')) {
        if (country === 'IN') {
          showGeoPopup(
            'You’re visiting from India. Would you like to visit our India store?',
            'Continue',
            'India Store',
            'https://www.rarabarefoot.in'
          );
        }
      }
    })
    .catch(err => console.error('Geo check failed:', err));

  // Popup creation function
  function showGeoPopup(message, stayBtnText, redirectBtnText, redirectUrl) {
    const overlay = document.createElement('div');
    overlay.style.cssText = `
      position: fixed;
      inset: 0;
      background: rgba(0,0,0,0.65);
      display: flex;
      align-items: center;
      justify-content: center;
      z-index: 999999;
    `;

    const popup = document.createElement('div');
    popup.style.cssText = `
      background: #fff;
      padding: 10px 20px;
      border-radius: 10px;
      text-align: center;
      max-width: 420px;
      width: 90%;
      box-shadow: 0 5px 25px rgba(0,0,0,0.3);
      font-family: Arial, sans-serif;
    `;

    popup.innerHTML = `
      <p style="font-size:16px; color:#333; margin-bottom:25px;">${message}</p>
      <div style="display:flex; justify-content:center; gap:10px;">
        <button id="stay-btn" 
          style="padding:10px 20px; background:#f3f3f3; border:1px solid #ccc; cursor:pointer;">
          ${stayBtnText}
        </button>
        <a id="redirect-btn" href="${redirectUrl}" 
          style="display:inline-block; padding:10px 20px; background:#000; color:#fff; text-decoration:none;">
          ${redirectBtnText}
        </a>
      </div>
    `;

    overlay.appendChild(popup);
    document.body.appendChild(overlay);

    // "Continue" button
    popup.querySelector('#stay-btn').addEventListener('click', () => {
      localStorage.setItem('geo_choice', 'stay');
      overlay.remove();
    });

    // "Redirect" button
    popup.querySelector('#redirect-btn').addEventListener('click', () => {
      localStorage.setItem('geo_choice', 'redirected');
    });
  }
});
</script>

