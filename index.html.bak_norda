<style id="rara-ultimate-style">/* ==========================================================================
   RARA BAREFOOT ULTIMATE PREMIUM STYLING (GULLY LABS CLONE)
   ========================================================================== */

/* 1. Logo Size and Transition */
body .header__logo-image {
    transition: width 0.3s ease, height 0.3s ease !important;
    width: 190px !important;
    height: auto !important;
    max-width: none !important;
}
body .header__logo-image.shrink {
    width: 150px !important;
}

@media screen and (max-width: 768px) {
    body .header__logo-image {
        width: 150px !important;
    }
    body .header__logo-image.shrink {
        width: 120px !important;
    }
}

/* 2. Enlarged & Dominant Headings + Font Spacing */
h1, h2, h3, h4 { 
    letter-spacing: 0.06em !important; 
}
body, a { 
    letter-spacing: 0.03em !important; 
}
.header__heading-link, .header__heading-logo, .header__heading {
    font-size: clamp(1.8rem, 3vw, 2.8rem) !important;
    font-family: 'Anton', sans-serif !important;
    letter-spacing: 0.08em !important;
    transition: all 0.4s ease !important;
}
body header.scrolled .header__heading-link, 
body header.scrolled .header__heading-logo {
    font-size: 1.4rem !important;
}

/* 3. Perfect Gradient Background (Starts from Pure White & goes to Light Gray) */
body .card__media, 
body .product-card__media, 
body .card-wrapper .media,
body .search-filters__product-image-wrapper, 
body .search-filters__product-image,
body .search-filters__product-item-grid-view-layout-image,
body .product-card__figure {
    background: linear-gradient(180deg, #ffffff 0%, #ececec 100%) !important;
    border-radius: 16px !important;
    position: relative !important;
    overflow: hidden !important;
    border: none !important;
    padding: 0 !important;
}

/* 4. Gully Labs Scrub Base CSS & Image Stacking + Brightness filter to make #f1f1f1 transparent */
body .card__media img, 
body .product-card__media img, 
body .card-wrapper .media img,
body .search-filters__product-image-wrapper img, 
body .search-filters__product-image img,
body .search-filters__product-item-grid-view-layout-image img {
    position: absolute !important;
    top: 0 !important;
    left: 0 !important;
    width: 100% !important;
    height: 100% !important;
    object-fit: contain !important; 
    mix-blend-mode: multiply !important; 
    filter: brightness(1.06) contrast(1.02) !important; /* Converts #f1f1f1 solid gray image background to pure white #ffffff so multiply blends it 100% transparently */
    z-index: 2 !important;
    transition: opacity 0.1s ease !important; 
    background: transparent !important;
}

/* Make the first image relative so container doesn't collapse */
body .card__media img:first-child, 
body .product-card__media img:first-child, 
body .card-wrapper .media img:first-child,
body .search-filters__product-image-wrapper img:first-child, 
body .search-filters__product-image img:first-child,
body .search-filters__product-item-grid-view-layout-image img:first-child {
    position: relative !important;
}

/* 5. Clean up any leftover overlay borders or backgrounds */
body .card__media::before, 
body .product-card__media::before, 
body .card-wrapper .media::before,
body .search-filters__product-image-wrapper::before, 
body .search-filters__product-image::before,
body .card__media::after, 
body .product-card__media::after, 
body .card-wrapper .media::after,
body .search-filters__product-image-wrapper::after, 
body .search-filters__product-image::after {
    display: none !important;
    background: transparent !important;
    opacity: 0 !important;
}

body .card-wrapper .card__content, 
body .card-wrapper:hover .card__content,
body .card__inner,
body .card__inner:hover,
body .product-card-wrapper .card__content {
    background-color: transparent !important;
    background: transparent !important;
}

/* 6. Scrub Hover Left-to-Right Visibility States */
body .is-hidden-by-scrub {
    opacity: 0 !important;
    z-index: 1 !important;
}
body .is-active-by-scrub {
    opacity: 1 !important;
    z-index: 3 !important;
}

/* 7. Side-by-Side Gender Portrait Banners */
.gender-banners-container {
    max-width: 1400px;
    margin: 40px auto;
    padding: 0 20px;
}
.gender-banners-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 24px;
    width: 100%;
}
.gender-banner-card {
    position: relative;
    display: block;
    aspect-ratio: 3 / 4;
    border-radius: 20px;
    overflow: hidden;
    text-decoration: none;
    background-color: #f7f7f7;
    border: 1px solid rgba(0,0,0,0.04);
    box-shadow: 0 4px 20px rgba(0, 0, 0, 0.02);
    transition: transform 0.4s cubic-bezier(0.16, 1, 0.3, 1), box-shadow 0.4s ease;
}
.gender-banner-card:hover {
    transform: translateY(-4px);
    box-shadow: 0 12px 30px rgba(0, 0, 0, 0.08);
}
.gender-banner-img {
    width: 100% !important;
    height: 100% !important;
    object-fit: cover !important;
    transition: transform 0.6s cubic-bezier(0.16, 1, 0.3, 1) !important;
}
.gender-banner-card:hover .gender-banner-img {
    transform: scale(1.04);
}
.gender-banner-overlay {
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    bottom: 0;
    background: linear-gradient(
        to top,
        rgba(0, 0, 0, 0.65) 0%,
        rgba(0, 0, 0, 0.2) 50%,
        rgba(0, 0, 0, 0) 100%
    );
    z-index: 1;
    transition: opacity 0.4s ease;
}
.gender-banner-content {
    position: absolute;
    bottom: 0;
    left: 0;
    right: 0;
    padding: 40px;
    z-index: 2;
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
}
.gender-banner-title {
    font-family: "Geist", "Outfit", sans-serif !important;
    font-size: clamp(1.8rem, 2.5vw, 2.8rem) !important;
    font-weight: 300 !important;
    color: #ffffff !important;
    margin-bottom: 20px !important;
    letter-spacing: 0.04em !important;
    line-height: 1.2 !important;
    text-transform: none !important;
}
.gender-banner-title em {
    font-family: "Playfair Display", "Didot", Garamond, serif !important;
    font-style: italic !important;
    font-weight: 400 !important;
}
.gender-banner-button {
    --button-background: 255 255 255;
    --button-outline-color: 255 255 255;
    --button-text-color: 0 0 0;
    min-width: 160px;
    backdrop-filter: blur(8px);
    background: rgba(255, 255, 255, 0.9) !important;
    color: #000000 !important;
    border: 1px solid #ffffff !important;
    transition: background 0.3s ease, color 0.3s ease, border-color 0.3s ease !important;
}
.gender-banner-card:hover .gender-banner-button {
    background: #ffffff !important;
    color: #000000 !important;
    box-shadow: 0 4px 15px rgba(255, 255, 255, 0.25);
}

/* Mobile Layout Support */
@media (max-width: 768px) {
    .gender-banners-container {
        margin: 20px auto;
        padding: 0 15px;
    }
    .gender-banners-grid {
        grid-template-columns: 1fr;
        gap: 16px;
    }
    .gender-banner-card {
        aspect-ratio: 4 / 5;
        border-radius: 16px;
    }
    .gender-banner-content {
        padding: 24px;
    }
    .gender-banner-title {
        margin-bottom: 15px !important;
    }
}

/* --- Premium Royal Blue Brand Accents & Ratings --- */
.benefit-title {
    color: #095492 !important;
}

/* Star Ratings styled in Premium Royal Blue */
.rating-badge__stars svg path,
.icon-star-rating path,
.icon-star-rating-half path {
    fill: #095492 !important;
}

.header__primary-nav-item a:hover,
.header-sidebar__linklist-button:hover,
.link-faded-reverse:hover,
.header__account-link a:hover,
.header__search-link a:hover,
.header__cart-link a:hover,
.top-header-content a:hover,
.top-links a:hover,
.top-header-links a:hover,
.top-help-links a:hover,
.help-menu a:hover,
.link-faded:hover {
    color: #095492 !important;
    transition: color 0.2s ease !important;
}

/* --- Premium CTA Hover Micro-Animations --- */
.button,
.product-card__quick-add-button,
.gender-banner-button,
.all-video-buttons,
.video__button {
    font-size: 1.02rem !important;
    padding: 12px 28px !important;
    border-radius: 8px !important; /* Soft, classy rounded corners */ /* Soft, classy rounded corners */
    transition: transform 0.3s cubic-bezier(0.25, 0.8, 0.25, 1), 
                box-shadow 0.3s cubic-bezier(0.25, 0.8, 0.25, 1), 
                background-color 0.3s cubic-bezier(0.25, 0.8, 0.25, 1), 
                color 0.3s cubic-bezier(0.25, 0.8, 0.25, 1), 
                border-color 0.3s cubic-bezier(0.25, 0.8, 0.25, 1) !important;
    will-change: transform, box-shadow !important; /* Forces GPU compositor layer, eliminating lag */
    backface-visibility: hidden !important; /* Hardware acceleration fallback */
    transform: translate3d(0, 0, 0) !important;
}

.button:hover,
.product-card__quick-add-button:hover,
.gender-banner-button:hover,
.all-video-buttons:hover,
.video__button:hover {
    transform: translate3d(0, -2px, 0) scale(1.015) !important; /* GPU-accelerated lift and micro-scale */
    box-shadow: 0 8px 20px rgba(9, 84, 146, 0.18) !important; /* Soft royal blue drop glow */
    background-color: #ffffff !important; /* Classy background invert on hover */
    color: #095492 !important; /* Premium brand royal blue text color */
    border-color: #095492 !important; /* Premium brand royal blue border color */
}

</style>

<script id="rara-ultimate-script">

// ==========================================================================
// RARA BAREFOOT ULTIMATE PREMIUM SCRIPTS (GULLY LABS CLONE)
// ==========================================================================

// 1. Navbar Scroll Shrink Logic
window.addEventListener('scroll', () => {
    const header = document.querySelector('header');
    const logo = document.querySelector('.header__logo-image');
    if (header) {
        if (window.scrollY > 60) {
            header.classList.add('scrolled');
        } else {
            header.classList.remove('scrolled');
        }
    }
    if (logo) {
        if (window.scrollY > 50) {
            logo.classList.add('shrink');
        } else {
            logo.classList.remove('shrink');
        }
    }
});

// 2. Gully Labs left-to-right shoe rotation hover scrub
(function() {
  const attached = new WeakSet();

  function attachScrub(card) {
    if (attached.has(card)) return;
    const images = card.querySelectorAll('img');
    if (images.length < 2) return;
    attached.add(card);

    function showImage(index) {
      images.forEach((img, i) => {
        img.classList.toggle('is-hidden-by-scrub', i !== index);
        img.classList.toggle('is-active-by-scrub', i === index);
      });
    }

    card.addEventListener('mousemove', function(e) {
      const rect = card.getBoundingClientRect();
      const pct = (e.clientX - rect.left) / rect.width;
      const idx = Math.min(Math.floor(pct * images.length), images.length - 1);
      showImage(Math.max(0, idx));
    });

    card.addEventListener('mouseleave', function() {
      images.forEach((img, i) => {
        img.classList.remove('is-hidden-by-scrub', 'is-active-by-scrub');
        img.style.opacity = i === 0 ? '1' : '0';
      });
      setTimeout(() => { images.forEach(img => img.style.opacity = ''); }, 50);
    });
  }

  function attachAll() {
    document.querySelectorAll('.card-wrapper, .product-card, .search-filters__product-image-container, .fdt-product-item-body, .product-card__figure').forEach(attachScrub);
  }

  attachAll();
  [300, 800, 2000, 4000].forEach(t => setTimeout(attachAll, t));
  new MutationObserver(attachAll).observe(document.body, { childList: true, subtree: true });
})();

</script>
<script id="product-scrub-hover-fix">

(function() {
  const productPhotos = {
    'uruk-blue-barefoot-shoes-men': ['/Uruk blue-1.JPG', '/Uruk blue-2.JPG', '/Uruk blue-3.JPG', '/Uruk blue-4.JPG'],
    'uruk-blue-barefoot-shoes-women': ['/Uruk blue-1.JPG', '/Uruk blue-2.JPG', '/Uruk blue-3.JPG', '/Uruk blue-4.JPG'],
    'uruk-neon-barefoot-shoes-men': ['/Uruk neo-1.JPG', '/uruk neo-2.JPG', '/uruk neo-3.JPG', '/Uruk neo-4.jpg'],
    'uruk-neon-barefoot-shoes-women': ['/Uruk neo-1.JPG', '/uruk neo-2.JPG', '/uruk neo-3.JPG', '/Uruk neo-4.jpg'],
    'uruk-white-barefoot-shoes-men': ['/Uruk white-1.JPG', '/Uruk white-2.JPG', '/Uruk white-3.JPG', '/Uruk white-4.JPG'],
    'uruk-white-barefoot-shoes-women': ['/Uruk white-1.JPG', '/Uruk white-2.JPG', '/Uruk white-3.JPG', '/Uruk white-4.JPG'],
    'xanadu-black-barefoot-shoes-men': ['/Xanadu black -1.JPG', '/Xanadu black -2.JPG', '/Xanadu black -3.JPG', '/Xanadu black -4.JPG'],
    'xanadu-black-barefoot-shoes-women': ['/Xanadu black -1.JPG', '/Xanadu black -2.JPG', '/Xanadu black -3.JPG', '/Xanadu black -4.JPG'],
    'xanadu-white-barefoot-shoes-men': ['/xanadu white-1.JPG', '/xanadu white-2.JPG', '/xanadu white-3.JPG', '/xanadu white-4.JPG'],
    'xanadu-white-barefoot-shoes-women': ['/xanadu white-1.JPG', '/xanadu white-2.JPG', '/xanadu white-3.JPG', '/xanadu white-4.JPG'],
    'zanzibar-blue-barefoot-shoes-men': ['/zanzibar blue-1.jpg', '/zanzibar blue-2.jpg', '/zanzibar blue-3.jpg', '/zanzibar blue-4.jpg'],
    'zanzibar-blue-barefoot-shoes-women': ['/zanzibar blue-1.jpg', '/zanzibar blue-2.jpg', '/zanzibar blue-3.jpg', '/zanzibar blue-4.jpg'],
    'zanzibar-yellow-barefoot-shoes-men': ['/zanzibar yellow-1.JPG', '/zanzibar yellow-2.JPG', '/zanzibar yellow-3.JPG', '/zanzibar yellow-4.JPG'],
    'zanzibar-yellow-barefoot-shoes-women': ['/zanzibar yellow-1.JPG', '/zanzibar yellow-2.JPG', '/zanzibar yellow-3.JPG', '/zanzibar yellow-4.JPG']
  };

  function initScrubHover() {
    const cards = document.querySelectorAll('product-card');
    cards.forEach(card => {
      const handle = card.getAttribute('handle');
      if (!handle || !productPhotos[handle]) return;

      const mediaContainer = card.querySelector('.product-card__media');
      if (!mediaContainer || card.dataset.scrubInitialized === 'true') return;

      card.dataset.scrubInitialized = 'true';
      card.classList.add('product-card--has-scrub');

      const photos = productPhotos[handle];

      // Create and append the 4 scrub images
      const scrubImages = [];
      photos.forEach((src, idx) => {
        const img = document.createElement('img');
        img.src = src;
        img.className = 'product-card__image product-card__image--scrub';
        if (idx === 0) img.classList.add('is-active');
        img.alt = card.querySelector('.product-title')?.textContent || 'Product Shot';
        img.setAttribute('draggable', 'false');
        img.setAttribute('loading', 'lazy');
        mediaContainer.appendChild(img);
        scrubImages.push(img);
      });

      // Create and append the dots container
      const dotsContainer = document.createElement('div');
      dotsContainer.className = 'product-scrub-dots';
      
      const dots = [];
      for (let i = 0; i < 4; i++) {
        const dot = document.createElement('div');
        dot.className = 'product-scrub-dot';
        if (i === 0) dot.classList.add('is-active');
        dotsContainer.appendChild(dot);
        dots.push(dot);
      }
      mediaContainer.appendChild(dotsContainer);

      let lastActiveIndex = 0;

      // Mousemove logic
      mediaContainer.addEventListener('mousemove', (e) => {
        const rect = mediaContainer.getBoundingClientRect();
        const x = e.clientX - rect.left;
        const width = rect.width;
        const pct = Math.max(0, Math.min(0.999, x / width));
        const activeIndex = Math.floor(pct * 4);

        if (activeIndex === lastActiveIndex) return;
        lastActiveIndex = activeIndex;

        scrubImages.forEach((img, idx) => {
          if (idx === activeIndex) {
            img.classList.add('is-active');
          } else {
            img.classList.remove('is-active');
          }
        });

        dots.forEach((dot, idx) => {
          if (idx === activeIndex) {
            dot.classList.add('is-active');
          } else {
            dot.classList.remove('is-active');
          }
        });
      });

      // Mouseleave logic
      mediaContainer.addEventListener('mouseleave', () => {
        lastActiveIndex = 0;
        scrubImages.forEach((img, idx) => {
          if (idx === 0) {
            img.classList.add('is-active');
          } else {
            img.classList.remove('is-active');
          }
        });
        dots.forEach((dot, idx) => {
          if (idx === 0) {
            dot.classList.add('is-active');
          } else {
            dot.classList.remove('is-active');
          }
        });
      });
    });
  }

  // Run on DOM load and Observer
  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', initScrubHover);
  } else {
    initScrubHover();
  }
  
  const observer = new MutationObserver(() => {
    initScrubHover();
  });
  observer.observe(document.body, { childList: true, subtree: true });
})();

</script>
