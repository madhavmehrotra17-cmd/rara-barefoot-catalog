<script>
document.addEventListener("DOMContentLoaded", function () {
  function toggleShiprocketButton() {
    // Select both buttons
    const selectSizeBtn = document.querySelector('button[data-select-size="true"], button.button--outline.w-full');
    const shiprocketDiv = document.querySelector('.shiprocket-headless[data-type="product"]');
    const shiprocketBtn = shiprocketDiv ? shiprocketDiv.querySelector('.sr-headless-checkout') : null;

    if (!shiprocketDiv || !shiprocketBtn) return;

    // Check if the Shopify button is disabled or has data-select-size="true"
    const isDisabled = selectSizeBtn && (selectSizeBtn.hasAttribute('disabled') || selectSizeBtn.getAttribute('data-select-size') === 'true');

    if (isDisabled) {
      // Disable Shiprocket button
      shiprocketBtn.style.opacity = "0.5";
      shiprocketBtn.style.cursor = "not-allowed";
      shiprocketBtn.style.pointerEvents = "none";
      shiprocketBtn.setAttribute("disabled", "true");

      // Optional: visually dim the parent div too
      shiprocketDiv.style.opacity = "0.6";
    } else {
      // Enable Shiprocket button
      shiprocketBtn.style.opacity = "1";
      shiprocketBtn.style.cursor = "pointer";
      shiprocketBtn.style.pointerEvents = "auto";
      shiprocketBtn.removeAttribute("disabled");

      // Restore parent div visibility
      shiprocketDiv.style.opacity = "1";
    }
  }

  // Run once initially
  toggleShiprocketButton();

  // Observe DOM changes — helps when variant/size buttons update dynamically
  const observer = new MutationObserver(toggleShiprocketButton);
  observer.observe(document.body, { childList: true, subtree: true });

  // Also check when any button is clicked (helps when size selection triggers state change)
  document.body.addEventListener("click", function () {
    setTimeout(toggleShiprocketButton, 200);
  });
});
</script>

