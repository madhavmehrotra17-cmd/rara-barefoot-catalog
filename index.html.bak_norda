    <style>
        /* INSTAGRAM FEED SECTION */
        .instagram-feed-section {
            width: 100%;
            background-color: #000000;
            overflow: hidden;
            border-top: 1px solid rgba(255, 255, 255, 0.05);
            padding: 0;
            margin: 0;
        }

        .instagram-grid {
            display: grid;
            grid-template-columns: repeat(5, 1fr);
            gap: 2px;
            width: 100%;
            margin: 0;
            padding: 0;
        }

        .instagram-item {
            position: relative;
            display: block;
            width: 100%;
            aspect-ratio: 1 / 1;
            overflow: hidden;
            background-color: #000;
        }

        .instagram-item img {
            width: 100%;
            height: 100%;
            object-fit: cover;
            display: block;
            transition: transform 0.5s cubic-bezier(0.25, 0.46, 0.45, 0.94);
        }

        .instagram-overlay {
            position: absolute;
            top: 0;
            left: 0;
            width: 100%;
            height: 100%;
            background-color: rgba(46, 98, 142, 0.65);
            display: flex;
            justify-content: center;
            align-items: center;
            opacity: 0;
            transition: opacity 0.35s ease;
            z-index: 2;
        }

        .instagram-icon-svg {
            width: 32px;
            height: 32px;
            fill: #ffffff;
            transform: scale(0.8);
            transition: transform 0.35s cubic-bezier(0.25, 0.46, 0.45, 0.94);
        }

        .instagram-item:hover img {
            transform: scale(1.06);
        }

        .instagram-item:hover .instagram-overlay {
            opacity: 1;
        }

        .instagram-item:hover .instagram-icon-svg {
            transform: scale(1);
        }

        .footer-info-bar {
            background-color: #000000;
            padding: 35px 8%;
            display: flex;
            justify-content: space-around;
            align-items: center;
            border-top: 1px solid rgba(255, 255, 255, 0.08);
            border-bottom: 1px solid rgba(255, 255, 255, 0.08);
            width: 100%;
            margin: 0;
            text-align: center;
            box-sizing: border-box;
        }

        .info-bar-item {
            display: flex;
            flex-direction: column;
            gap: 6px;
            align-items: center;
        }

        .info-bar-title {
            color: #ffffff;
            font-size: 0.95rem;
            font-weight: 700;
            letter-spacing: 0.03em;
            text-transform: none;
            font-family: Anton, Geist, sans-serif;
        }

        .info-bar-link {
            color: #ffffff;
            font-size: 0.9rem;
            font-weight: 700;
            text-decoration: underline;
            text-underline-offset: 4px;
            letter-spacing: 0.03em;
            transition: color 0.25s ease;
            font-family: Anton, Geist, sans-serif;
        }

        .info-bar-link:hover {
            color: #2E628E;
        }

        @media (max-width: 1024px) {
            .instagram-grid {
                grid-template-columns: repeat(5, 1fr);
            }
        }

        @media (max-width: 768px) {
            .instagram-grid {
                grid-template-columns: repeat(3, 1fr);
            }
            .footer-info-bar {
                flex-direction: column;
                gap: 24px;
                padding: 25px 4%;
            }
        }

        @media (max-width: 480px) {
            .instagram-grid {
                grid-template-columns: repeat(2, 1fr);
            }
        }
    </style>

