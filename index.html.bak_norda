<script>window.ShopifyAnalytics = window.ShopifyAnalytics || {};window.ShopifyAnalytics.performance = window.ShopifyAnalytics.performance || {};(function () {const LONG_FRAME_THRESHOLD = 50;const longAnimationFrames = [];let activeRafId = null;function collectLongFrames() {let previousTime = null;function rafMonitor(now) {if (activeRafId === null) {return;}const delta = now - previousTime;if (delta > LONG_FRAME_THRESHOLD) {longAnimationFrames.push({startTime: previousTime,endTime: now,});}previousTime = now;activeRafId = requestAnimationFrame(rafMonitor);}previousTime = performance.now();activeRafId = requestAnimationFrame(rafMonitor);}if (!PerformanceObserver.supportedEntryTypes.includes('long-animation-frame')) {collectLongFrames();const timeoutId = setTimeout(() => {cancelAnimationFrame(activeRafId);}, 10_000);window.ShopifyAnalytics.performance.getLongAnimationFrames = function(stopCollection = false) {if (stopCollection) {clearTimeout(timeoutId);cancelAnimationFrame(activeRafId);}return longAnimationFrames;};}})();</script>

<style id="premium-footer-styles">
           5. INSTAGRAM FEED SECTION (HORIZONTAL GRID OF 5 ROW)
           ========================================================================= */
        .instagram-feed-section {
            width: 100%;
            background-color: #000000;
            overflow: hidden;
            border-top: 1px solid rgba(255, 255, 255, 0.05);
            padding: 0;
            margin: 0;
        }

        .instagram-grid {
            display: grid;
            grid-template-columns: repeat(5, 1fr);
            gap: 2px; /* Very subtle 2px gap to define each square beautifully */
            width: 100%;
            margin: 0;
            padding: 0;
        }

        .instagram-item {
            position: relative;
            display: block;
            width: 100%;
            aspect-ratio: 1 / 1; /* Force perfect squares */
            overflow: hidden;
            background-color: #000;
        }

        .instagram-item img {
            width: 100%;
            height: 100%;
            object-fit: cover;
            display: block;
            transition: transform 0.5s cubic-bezier(0.25, 0.46, 0.45, 0.94);
        }

        /* Hover Overlay */
        .instagram-overlay {
            position: absolute;
            top: 0;
            left: 0;
            width: 100%;
            height: 100%;
            background-color: rgba(46, 98, 142, 0.65); /* Rich transparent Uruk Blue matching brand */
            display: flex;
            justify-content: center;
            align-items: center;
            opacity: 0;
            transition: opacity 0.35s ease;
            z-index: 2;
        }

        /* SVG Instagram Camera Icon in White */
        .instagram-icon-svg {
            width: 32px;
            height: 32px;
            fill: #ffffff;
            transform: scale(0.8);
            transition: transform 0.35s cubic-bezier(0.25, 0.46, 0.45, 0.94);
        }

        /* Hover Tactile Interactions */
        .instagram-item:hover img {
            transform: scale(1.06);
        }

        .instagram-item:hover .instagram-overlay {
            opacity: 1;
        }

        .instagram-item:hover .instagram-icon-svg {
            transform: scale(1);
        }

        /* Responsive Adapters */
        @media (max-width: 1024px) {
            .instagram-grid {
                grid-template-columns: repeat(5, 1fr);
            }
        }

        @media (max-width: 768px) {
            .instagram-grid {
                grid-template-columns: repeat(3, 1fr);
            }
        }

        @media (max-width: 480px) {
            .instagram-grid {
                grid-template-columns: repeat(2, 1fr);
            }
        }

        /* Footer Info Bar (Black banner with links) */
        .footer-info-bar {
            background-color: #000000;
            padding: 35px 8%;
            display: flex;
            justify-content: space-around;
            align-items: center;
            border-top: 1px solid rgba(255, 255, 255, 0.08);
            border-bottom: 1px solid rgba(255, 255, 255, 0.08);
            width: 100%;
            margin: 0;
            text-align: center;
            box-sizing: border-box;
        }

        .info-bar-item {
            display: flex;
            flex-direction: column;
            gap: 6px;
            align-items: center;
        }

        .info-bar-title {
            color: #ffffff;
            font-size: 0.95rem;
            font-weight: 700;
            letter-spacing: 0.03em;
            text-transform: none;
            font-family: var(--font-main);
        }

        .info-bar-link {
            color: #ffffff;
            font-size: 0.9rem;
            font-weight: 700;
            text-decoration: underline;
            text-underline-offset: 4px;
            letter-spacing: 0.03em;
            transition: color 0.25s ease;
            font-family: var(--font-main);
        }

        .info-bar-link:hover {
            color: var(--uruk-blue);
        }

        @media (max-width: 768px) {
            .footer-info-bar {
                flex-direction: column;
                gap: 24px;
                padding: 25px 4%;
            }
        }

        /* ==========================================================================
           6. PREMIUM BRAND FOOTER SECTION (CHARCOAL LUXURY VIBE)
           ========================================================================= */
        .premium-footer {
            background-color: #111111; /* Solid charcoal matching website's elegant, high-contrast dark elements */
            color: #ffffff;
            padding: 80px 6% 40px 6%;
            font-family: var(--font-main);
            border-top: 1px solid rgba(255, 255, 255, 0.08);
            position: relative;
            z-index: 10;
        }

        .footer-grid {
            display: grid;
            grid-template-columns: 1.5fr 1fr 1fr 1fr 1.8fr;
            gap: 40px;
            width: 100%;
            max-width: 1300px;
            margin: 0 auto;
        }

        /* Column 1: Logo & Socials */
        .footer-brand-column {
            display: flex;
            flex-direction: column;
            gap: 25px;
        }

        .footer-brand-logo img {
            height: 90px;
            width: auto;
            object-fit: contain;
            display: block;
            filter: brightness(0) invert(1); /* Render white logo on dark background */
        }

        .footer-social-wrapper {
            display: flex;
            align-items: center;
            gap: 12px;
            flex-wrap: wrap;
        }

        .footer-social-label {
            font-family: 'Anton', sans-serif;
            font-size: 1.05rem;
            letter-spacing: 0.12em;
            color: #ffffff;
            text-transform: uppercase;
        }

        .footer-social-icons {
            display: flex;
            align-items: center;
            gap: 10px;
        }

        .footer-social-icons a {
            display: inline-flex;
            align-items: center;
            justify-content: center;
            transition: transform 0.25s ease;
        }

        .footer-social-icons a:hover {
            transform: scale(1.15);
        }

        .footer-social-icons img {
            width: 32px;
            height: 32px;
            object-fit: contain;
        }

        /* Links Columns (Collections, Help, Company) */
        .footer-links-column {
            display: flex;
            flex-direction: column;
            gap: 20px;
        }

        .footer-links-column h4 {
            font-family: 'Anton', sans-serif;
            font-size: 1.1rem;
            letter-spacing: 0.1em;
            text-transform: uppercase;
            color: #ffffff;
            font-weight: 400;
        }

        .footer-links-list {
            list-style: none;
            display: flex;
            flex-direction: column;
            gap: 12px;
            padding: 0;
            margin: 0;
        }

        .footer-links-list a {
            color: rgba(255, 255, 255, 0.7);
            text-decoration: none;
            font-size: 0.88rem;
            font-weight: 500;
            transition: color 0.2s ease, padding-left 0.2s ease;
            display: inline-block;
        }

        .footer-links-list a:hover {
            color: #ffffff;
            padding-left: 2px;
        }

        /* Column 5: Contact Info & Address */
        .footer-contact-column {
            display: flex;
            flex-direction: column;
            gap: 20px;
        }

        .footer-contact-rows {
            display: flex;
            flex-direction: column;
            gap: 18px;
        }

        .footer-contact-row {
            display: flex;
            align-items: flex-start;
            gap: 14px;
        }

        .footer-contact-row img {
            width: 24px;
            height: 24px;
            object-fit: contain;
            flex-shrink: 0;
            margin-top: 2px;
        }

        .footer-contact-text {
            font-size: 0.85rem;
            line-height: 1.5;
            color: rgba(255, 255, 255, 0.85);
            font-weight: 400;
        }

        .footer-contact-text a {
            color: #ffffff;
            text-decoration: none;
            transition: opacity 0.2s ease;
        }

        .footer-contact-text a:hover {
            opacity: 0.8;
            text-decoration: underline;
        }

        /* Bottom Row: Divider & Copyright */
        .footer-bottom {
            margin-top: 60px;
            border-top: 1px solid rgba(255, 255, 255, 0.06);
            padding-top: 30px;
            display: flex;
            justify-content: flex-end;
            width: 100%;
            max-width: 1300px;
            margin-inline: auto;
        }

        .footer-copyright {
            font-size: 0.72rem;
            color: rgba(255, 255, 255, 0.5);
            letter-spacing: 0.08em;
            text-transform: uppercase;
            font-weight: 600;
        }

        .footer-copyright a {
            color: rgba(255, 255, 255, 0.5);
            text-decoration: none;
        }

        .footer-copyright a:hover {
            color: #ffffff;
        }

        /* Responsive Breakpoint handling for mobile/tablets */
        @media (max-width: 1024px) {
            .premium-footer {
                padding: 60px 4% 30px 4%;
            }
            .footer-grid {
                grid-template-columns: repeat(2, 1fr);
                gap: 40px;
            }
            .footer-brand-column {
                grid-column: span 2;
                align-items: center;
                text-align: center;
            }
            .footer-contact-column {
                grid-column: span 2;
            }
            .footer-bottom {
                margin-top: 40px;
                justify-content: center;
                text-align: center;
            }
        }

        @media (max-width: 600px) {
            .footer-grid {
                grid-template-columns: 1fr;
                gap: 30px;
            }
            .footer-brand-column, .footer-contact-column {
                grid-column: span 1;
                align-items: flex-start;
                text-align: left;
            }
            .footer-brand-logo img {
                height: 80px;
            }
            .footer-links-column {
                gap: 12px;
            }
        }
</style>
<style id="ultimate-fix">

/* 1. Safe Gradient Background (Strictly behind image) */
.card__media, .product-card__media, .card-wrapper .media {
    background: linear-gradient(180deg, #FFFFFF 0%, rgba(255,255,255,0) 45%) !important;
}

/* 2. Remove all overlays that could cover the product */
.card__media::before, .product-card__media::before, .card-wrapper .media::before,
.card__media::after, .product-card__media::after, .card-wrapper .media::after {
    display: none !important;
    background: transparent !important;
}

/* 3. Ensure product image is completely unmodified and on top */
.card__media img, .product-card__media img, .card-wrapper .media img {
    position: relative !important;
    z-index: 2 !important;
    mix-blend-mode: normal !important;
    background: transparent !important;
    opacity: 1; /* prevent hover script from hiding it completely */
}

</style>
</head>

