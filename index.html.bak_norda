  <title>Footer Section</title>
  <style>
    .footer-section {
      display: flex;
      justify-content: space-between;
      margin: 0 auto;
      align-items: center;
      background-color: #000000;
    
      padding: 20px;
      flex-wrap: wrap; /* mobile responsive */
    }

    .footer-column {
      flex: 1;
      
      background-color: #000000;
      border-radius: 20px;
      min-width: 250px; /* responsive width */
    }

    .footer-column h3 {
      font-weight: bold;
      color: #ffffff;
      margin: 5px 0;
    }

    .footer-column p {
      font-size: 14px;
      color: #ffffff;
      margin: 0;
    }

    .footer-column img {
      height: 30px;
      width: auto;
    }

    .footer-links {
      margin: 10px;
      display: flex;
      justify-content: center;
      flex-wrap: wrap;
      gap: 5px;
    }

    .footer-column h3 a {
      color: #ffffff;
     text-decoration: underline;
      font-size: 14px;
      font-weight: bold;
    }

    .footer-links a:hover {
      text-decoration: underline;
    }
  </style>
</head>
